# Database Configuration
# PostgreSQL (production)
# DATABASE_URL=postgresql://your_user:your_password@127.0.0.1:5432/pii_system
# SQLite (development fallback)
DATABASE_URL=sqlite:///./data/pii_system.db

# Database Connection Pool Settings
DATABASE_POOL_SIZE=2
DATABASE_ECHO=false

# Application Configuration
APP_NAME="AI De-identification System"
APP_VERSION="1.0.0"
# Generate strong keys for production use:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# File Storage
UPLOAD_DIR=./data/input
OUTPUT_DIR=./data/output
TEMP_DIR=./data/temp
MAX_FILE_SIZE_MB=100

# OCR Configuration
# TESSERACT_CMD="C:/Program Files/Tesseract-OCR/tesseract.exe"
TESSERACT_LANGUAGES=["eng"]
OCR_CONFIDENCE_THRESHOLD=0.6

# PII Detection Configuration
MODEL_CACHE_DIR=./models
SPACY_MODEL=en_core_web_lg
PII_CONFIDENCE_THRESHOLD=0.8

# Workflow Configuration
# PREFECT_SERVER_URL=http://localhost:4200
# REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/application.log

# Security
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Performance
MAX_CONCURRENT_JOBS=2
BATCH_SIZE=10
JOB_TIMEOUT_MINUTES=5

DEBUG=false
ENABLE_GPU=false
