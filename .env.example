# Database Configuration
DATABASE_URL=postgresql://deidentify_user:secure_password@localhost:5432/deidentify_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deidentify_db
DB_USER=deidentify_user
DB_PASSWORD=secure_password

# Application Configuration
APP_NAME="AI De-identification System"
APP_VERSION="1.0.0"
API_V1_STR="/api/v1"
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_PATH=./data/input
OUTPUT_PATH=./data/output
TEMP_PATH=./data/temp
MAX_FILE_SIZE=100000000  # 100MB in bytes

# OCR Configuration
TESSERACT_CMD=tesseract  # Path to tesseract executable
OCR_LANGUAGES=eng
OCR_CONFIDENCE_THRESHOLD=60

# PII Detection Configuration
PRESIDIO_MODELS_PATH=./models
SPACY_MODEL=en_core_web_sm
PII_CONFIDENCE_THRESHOLD=0.8

# Workflow Configuration
PREFECT_SERVER_URL=http://localhost:4200
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Security
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# Performance
MAX_WORKERS=4
BATCH_SIZE=10
PROCESSING_TIMEOUT=300  # 5 minutes