# Application Settings
APP_NAME="PII De-identification System"
APP_VERSION="1.0.0"
DEBUG=True
LOG_LEVEL="INFO"

# API Configuration
API_HOST="localhost"
API_PORT=8000
API_WORKERS=1
API_RELOAD=True

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Database Configuration
DATABASE_URL="sqlite:///./data/pii_system.db"
DATABASE_POOL_SIZE=5
DATABASE_ECHO=False

# Model Configuration
MODEL_CACHE_DIR="./models/cache"
MODEL_DOWNLOAD_DIR="./models/downloads"
ENABLE_GPU=True
MAX_GPU_MEMORY_MB=6000
MODEL_DEVICE="cuda"  # or "cpu"

# Mistral Configuration
MISTRAL_MODEL="mistral:7b-instruct"
MISTRAL_TIMEOUT=300
MISTRAL_MAX_TOKENS=512
MISTRAL_TEMPERATURE=0.1

# Security
SECRET_KEY="your-secret-key-here-change-in-production"
ENCRYPTION_KEY="your-encryption-key-here-change-in-production"
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=["pdf", "png", "jpg", "jpeg", "tiff", "tif"]

# Processing Configuration
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_MINUTES=30
CLEANUP_TEMP_FILES_HOURS=24
BATCH_SIZE=10

# Airflow Configuration
AIRFLOW_HOME="./orchestration"
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_EXECUTOR="LocalExecutor"
AIRFLOW_DATABASE_URL="sqlite:///./data/airflow.db"

# OCR Configuration
TESSERACT_LANGUAGES=["eng", "hin"]
PADDLEOCR_USE_GPU=True
OCR_CONFIDENCE_THRESHOLD=0.7

# PII Detection Configuration
SPACY_MODEL="en_core_web_lg"
PII_CONFIDENCE_THRESHOLD=0.8
ENABLE_CUSTOM_NER=True

# Storage Configuration
UPLOAD_DIR="./data/input"
PROCESSING_DIR="./data/processing"
OUTPUT_DIR="./data/output"
AUDIT_DIR="./data/audit"
TEMP_DIR="./data/temp"

# Logging Configuration
LOG_FILE="./logs/application.log"
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5

# Monitoring Configuration
ENABLE_METRICS=True
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# Development Configuration
ENABLE_DEBUG_ENDPOINTS=True
ENABLE_SWAGGER_UI=True
ENABLE_RELOAD=True
